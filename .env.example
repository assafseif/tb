# ============================================================
# AI News Futures Trading Bot - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# ---- Database ----
DB_HOST=109.205.180.47
DB_PORT=1433
DB_NAME=tradingbot
DB_USERNAME=sa
DB_PASSWORD=TradingBot@123

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- AI Wrapper (Claude) ----
# The external AI API endpoint (running on host machine)
AI_BASE_URL=http://localhost:8889

# ---- Binance Futures Testnet API Keys ----
# Get keys from: https://testnet.binancefuture.com/
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ---- Trading Flags ----
# PAPER_TRADING_ENABLED=true  -> trades simulated only (default)
# TRADING_ENABLED=true        -> enables real Binance API calls (DANGER)
TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true

# ---- Risk Parameters ----
RISK_MAX_PER_TRADE=0.01      # 1% of account per trade
RISK_MAX_DAILY_LOSS=0.03     # 3% max daily loss
RISK_MAX_OPEN_TRADES=3        # max concurrent positions
RISK_MIN_CONFIDENCE=80        # minimum AI confidence to trade

# ---- Account ----
ACCOUNT_LEVERAGE=5            # futures leverage
# Balance is fetched automatically from Binance at startup — no config needed
